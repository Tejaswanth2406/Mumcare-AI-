<!-- ─── CODE ─── -->
<section class="code-bg" id="code">
  <div class="section-wrap">
    <div class="section-label">Implementation</div>
    <h2 class="section-title">Production-Grade <em>Code</em></h2>
    <p class="section-sub">Cleanly architected, modular, and ready to integrate with the real Mumzworld product catalog.</p>

    <div class="code-grid fade-up">
      <div class="code-block">
        <div class="code-header">
          <div class="dot dot-r"></div><div class="dot dot-y"></div><div class="dot dot-g"></div>
          <div class="code-filename">services/intent_parser.py</div>
        </div>
        <pre>
<span class="cm"># Intent extraction with confidence scoring</span>
<span class="kw">async def</span> <span class="fn">parse_intent</span>(query: str) -> IntentResult:
    prompt = <span class="str">f"""
    Analyze this query and respond with JSON only:
    Query: {query}
    
    Return:
    - intent: postpartum_care|feeding|
              baby_care|general|unknown
    - confidence: 0.0-1.0
    - is_medical_emergency: bool
    - issue_summary: str
    """</span>
    
    response = <span class="kw">await</span> <span class="fn">call_llm</span>(prompt)
    result = <span class="fn">IntentResult</span>(**json.loads(response))
    
    <span class="cm"># Safety gate: flag medical urgency</span>
    <span class="kw">if</span> result.is_medical_emergency:
        result.uncertainty = <span class="kw">True</span>
    
    <span class="kw">return</span> result</pre>
      </div>

      <div class="code-block">
        <div class="code-header">
          <div class="dot dot-r"></div><div class="dot dot-y"></div><div class="dot dot-g"></div>
          <div class="code-filename">services/retriever.py</div>
        </div>
        <pre>
<span class="cm"># RAG retrieval — keyword + tag matching</span>
<span class="kw">def</span> <span class="fn">retrieve_products</span>(
    intent: str, query: str, top_k: <span class="fn">int</span> = <span class="num">5</span>
) -> List[Product]:
    
    keywords = <span class="fn">extract_keywords</span>(query)
    scored = []
    
    <span class="kw">for</span> product <span class="kw">in</span> product_db:
        score = <span class="num">0</span>
        
        <span class="cm"># Category match (high weight)</span>
        <span class="kw">if</span> intent <span class="kw">in</span> product.categories:
            score += <span class="num">3</span>
        
        <span class="cm"># Keyword overlap in tags</span>
        matches = keywords & set(product.tags)
        score += len(matches) * <span class="num">2</span>
        
        scored.<span class="fn">append</span>((score, product))
    
    <span class="cm"># Return top-k most relevant</span>
    <span class="kw">return</span> [p <span class="kw">for</span> _, p <span class="kw">in</span> 
            <span class="fn">sorted</span>(scored, reverse=<span class="kw">True</span>)[:top_k]]</pre>
      </div>

      <div class="code-block">
        <div class="code-header">
          <div class="dot dot-r"></div><div class="dot dot-y"></div><div class="dot dot-g"></div>
          <div class="code-filename">core/schema.py</div>
        </div>
        <pre>
<span class="cm"># Pydantic schema — strict output validation</span>
<span class="kw">class</span> <span class="fn">ProductRecommendation</span>(BaseModel):
    product_id: int
    product_name: str
    reason: str
    usage_guidance_en: str
    usage_guidance_ar: str
    review_summary: str
    confidence: <span class="fn">float</span> = <span class="fn">Field</span>(ge=<span class="num">0</span>, le=<span class="num">1</span>)

<span class="kw">class</span> <span class="fn">MumCareResponse</span>(BaseModel):
    query: str
    intent: <span class="fn">IntentCategory</span>
    comfort_message: <span class="fn">BilingualMessage</span>
    recommendations: <span class="fn">List</span>[ProductRecommendation]
    confidence: <span class="fn">float</span>
    uncertainty: bool  <span class="cm"># True for medical</span>
    guidance: str</pre>
      </div>

      <div class="code-block">
        <div class="code-header">
          <div class="dot dot-r"></div><div class="dot dot-y"></div><div class="dot dot-g"></div>
          <div class="code-filename">routes/ai.py — API Response</div>
        </div>
        <pre>
<span class="cm">// POST /ai/query — structured output</span>
{
  <span class="str">"query"</span>: <span class="str">"I have leakage after childbirth"</span>,
  <span class="str">"intent"</span>: <span class="str">"postpartum_care"</span>,
  <span class="str">"comfort_message"</span>: {
    <span class="str">"en"</span>: <span class="str">"This is quite common after childbirth..."</span>,
    <span class="str">"ar"</span>: <span class="str">"هذا شائع جداً بعد الولادة..."</span>
  },
  <span class="str">"recommendations"</span>: [{
    <span class="str">"product_name"</span>: <span class="str">"Comfort Nursing Pads"</span>,
    <span class="str">"reason"</span>: <span class="str">"Designed for postpartum leakage"</span>,
    <span class="str">"confidence"</span>: <span class="num">0.95</span>
  }],
  <span class="str">"confidence"</span>: <span class="num">0.9</span>,
  <span class="str">"uncertainty"</span>: <span class="kw">false</span>
}</pre>
      </div>
    </div>
  </div>
</section>

