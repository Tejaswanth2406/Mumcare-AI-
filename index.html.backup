<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>MumCare AI — Mumzworld AI Intern Assignment</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=DM+Sans:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
<style>
  :root {
    --mum-pink: #E8157D;
    --mum-deep: #B01060;
    --mum-light: #FF6BAE;
    --mum-blush: #FFF0F7;
    --mum-rose: #FFD6EC;
    --gold: #F4A623;
    --gold-light: #FFF3D4;
    --dark: #1A0A12;
    --dark-mid: #2E1020;
    --text: #3D1A28;
    --muted: #8B5A72;
    --white: #FFFBFD;
    --card-bg: rgba(255,255,255,0.85);
    --glass: rgba(255,240,247,0.6);
    --shadow: 0 8px 40px rgba(232,21,125,0.12);
    --shadow-deep: 0 20px 80px rgba(232,21,125,0.22);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--white);
    color: var(--text);
    overflow-x: hidden;
  }

  /* ─── BACKGROUND MESH ─── */
  body::before {
    content: '';
    position: fixed; inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 10% 0%, rgba(232,21,125,0.08) 0%, transparent 60%),
      radial-gradient(ellipse 60% 80% at 90% 20%, rgba(244,166,35,0.06) 0%, transparent 55%),
      radial-gradient(ellipse 70% 50% at 50% 100%, rgba(232,21,125,0.06) 0%, transparent 60%);
    pointer-events: none; z-index: 0;
  }

  /* ─── NAV ─── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 18px 60px;
    backdrop-filter: blur(20px);
    background: rgba(255,251,253,0.88);
    border-bottom: 1px solid rgba(232,21,125,0.12);
  }
  .nav-logo {
    display: flex; align-items: center; gap: 12px;
  }
  .nav-logo-mark {
    width: 36px; height: 36px;
    background: linear-gradient(135deg, var(--mum-pink), var(--gold));
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Playfair Display', serif;
    color: white; font-weight: 900; font-size: 18px;
  }
  .nav-brand {
    font-family: 'Playfair Display', serif;
    font-weight: 700; font-size: 1.1rem; color: var(--dark);
    letter-spacing: -0.3px;
  }
  .nav-brand span { color: var(--mum-pink); }
  .nav-links {
    display: flex; align-items: center; gap: 32px;
    list-style: none;
  }
  .nav-links a {
    text-decoration: none; color: var(--muted); font-size: 0.875rem; font-weight: 500;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--mum-pink); }
  .nav-badge {
    background: linear-gradient(135deg, var(--mum-pink), var(--mum-deep));
    color: white; padding: 8px 20px; border-radius: 100px;
    font-size: 0.8rem; font-weight: 600; letter-spacing: 0.3px;
    text-decoration: none;
  }

  /* ─── HERO ─── */
  .hero {
    position: relative; z-index: 1;
    min-height: 100vh;
    display: flex; align-items: center;
    padding: 120px 60px 80px;
  }
  .hero-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 80px; align-items: center; max-width: 1300px; margin: 0 auto; width: 100%;
  }
  .hero-eyebrow {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--gold-light); border: 1px solid rgba(244,166,35,0.3);
    color: #9B6A00; padding: 6px 14px; border-radius: 100px;
    font-size: 0.75rem; font-weight: 600; letter-spacing: 1px; text-transform: uppercase;
    margin-bottom: 28px;
  }
  .hero-eyebrow::before {
    content: ''; width: 6px; height: 6px; border-radius: 50%;
    background: var(--gold); display: inline-block;
  }
  .hero-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.8rem, 5vw, 4.4rem);
    font-weight: 900; line-height: 1.08;
    color: var(--dark); margin-bottom: 24px;
  }
  .hero-title em {
    font-style: italic; color: var(--mum-pink);
    background: linear-gradient(135deg, var(--mum-pink), var(--gold));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-sub {
    font-size: 1.1rem; color: var(--muted); line-height: 1.7; max-width: 520px; margin-bottom: 40px;
  }
  .hero-ctas {
    display: flex; align-items: center; gap: 16px; flex-wrap: wrap;
  }
  .btn-primary {
    background: linear-gradient(135deg, var(--mum-pink) 0%, var(--mum-deep) 100%);
    color: white; padding: 14px 32px; border-radius: 12px;
    font-weight: 600; font-size: 0.95rem; text-decoration: none;
    box-shadow: 0 6px 24px rgba(232,21,125,0.35);
    transition: transform 0.2s, box-shadow 0.2s;
    display: inline-flex; align-items: center; gap: 8px;
  }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 10px 36px rgba(232,21,125,0.45); }
  .btn-outline {
    border: 2px solid rgba(232,21,125,0.3); color: var(--mum-pink);
    padding: 12px 28px; border-radius: 12px; font-weight: 600; font-size: 0.95rem;
    text-decoration: none; transition: all 0.2s; background: transparent;
    display: inline-flex; align-items: center; gap: 8px;
  }
  .btn-outline:hover { background: var(--mum-blush); border-color: var(--mum-pink); }

  /* ─── HERO VISUAL ─── */
  .hero-visual {
    position: relative;
  }
  .hero-card {
    background: white;
    border-radius: 24px;
    padding: 32px;
    box-shadow: var(--shadow-deep);
    border: 1px solid rgba(232,21,125,0.08);
    position: relative; overflow: hidden;
  }
  .hero-card::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 4px;
    background: linear-gradient(90deg, var(--mum-pink), var(--gold), var(--mum-light));
  }
  .chat-header {
    display: flex; align-items: center; gap: 12px; margin-bottom: 24px;
    padding-bottom: 16px; border-bottom: 1px solid var(--mum-rose);
  }
  .chat-avatar {
    width: 40px; height: 40px; border-radius: 12px;
    background: linear-gradient(135deg, var(--mum-pink), var(--gold));
    display: flex; align-items: center; justify-content: center;
    color: white; font-weight: 800; font-size: 16px;
    font-family: 'Playfair Display', serif;
  }
  .chat-title { font-weight: 700; font-size: 0.95rem; color: var(--dark); }
  .chat-status { display: flex; align-items: center; gap: 6px; font-size: 0.75rem; color: #22C55E; }
  .chat-status::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: #22C55E; display: inline-block; }
  .chat-msg { margin-bottom: 14px; }
  .chat-msg.user { text-align: right; }
  .chat-bubble {
    display: inline-block; padding: 10px 16px; border-radius: 18px;
    font-size: 0.875rem; line-height: 1.5; max-width: 85%;
  }
  .chat-bubble.user-bubble {
    background: linear-gradient(135deg, var(--mum-pink), var(--mum-deep));
    color: white; border-bottom-right-radius: 4px;
  }
  .chat-bubble.ai-bubble {
    background: var(--mum-blush); color: var(--text); border-bottom-left-radius: 4px;
    border: 1px solid var(--mum-rose);
  }
  .product-chips {
    display: flex; gap: 8px; flex-wrap: wrap; margin-top: 10px;
  }
  .product-chip {
    background: white; border: 1px solid var(--mum-rose);
    padding: 6px 12px; border-radius: 20px; font-size: 0.76rem; color: var(--mum-deep);
    font-weight: 600; display: flex; align-items: center; gap: 6px;
  }
  .product-chip::before { content: '✦'; font-size: 0.6rem; color: var(--mum-pink); }
  .confidence-bar {
    margin-top: 16px; padding: 12px 16px;
    background: linear-gradient(135deg, rgba(34,197,94,0.08), rgba(34,197,94,0.04));
    border: 1px solid rgba(34,197,94,0.2); border-radius: 10px;
    display: flex; align-items: center; gap: 10px; font-size: 0.78rem; color: #166534;
  }

  /* floating decorations */
  .float-pill {
    position: absolute; background: white;
    border-radius: 100px; padding: 10px 18px;
    font-size: 0.78rem; font-weight: 600;
    box-shadow: var(--shadow); border: 1px solid rgba(232,21,125,0.1);
    display: flex; align-items: center; gap: 8px;
    animation: float 4s ease-in-out infinite;
  }
  .float-pill.p1 { top: -20px; right: 20px; animation-delay: 0s; color: var(--mum-deep); }
  .float-pill.p2 { bottom: -16px; left: -10px; animation-delay: 1.5s; color: #166534; }
  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-8px); }
  }

  /* ─── STATS ─── */
  .stats-row {
    position: relative; z-index: 1;
    background: linear-gradient(135deg, var(--dark) 0%, var(--dark-mid) 100%);
    padding: 60px;
  }
  .stats-inner {
    max-width: 1300px; margin: 0 auto;
    display: grid; grid-template-columns: repeat(5, 1fr); gap: 0;
  }
  .stat-item {
    text-align: center; padding: 20px;
    border-right: 1px solid rgba(255,255,255,0.08);
  }
  .stat-item:last-child { border-right: none; }
  .stat-num {
    font-family: 'Playfair Display', serif;
    font-size: 2.4rem; font-weight: 900; color: white;
    background: linear-gradient(135deg, var(--mum-light), var(--gold));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  .stat-label { font-size: 0.78rem; color: rgba(255,255,255,0.45); margin-top: 4px; font-weight: 500; letter-spacing: 0.5px; }

  /* ─── SECTIONS ─── */
  section { position: relative; z-index: 1; }
  .section-wrap { max-width: 1300px; margin: 0 auto; padding: 100px 60px; }
  .section-label {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--mum-blush); color: var(--mum-deep);
    padding: 5px 14px; border-radius: 100px; font-size: 0.72rem;
    font-weight: 700; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 20px;
  }
  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 3.5vw, 3rem); font-weight: 900;
    color: var(--dark); line-height: 1.15; margin-bottom: 16px;
  }
  .section-title em { font-style: italic; color: var(--mum-pink); }
  .section-sub { font-size: 1rem; color: var(--muted); line-height: 1.7; max-width: 560px; }

  /* ─── PROBLEM / SOLUTION ─── */
  .ps-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 40px; margin-top: 60px;
  }
  .ps-card {
    border-radius: 20px; padding: 40px; position: relative; overflow: hidden;
  }
  .ps-card.problem { background: var(--dark); }
  .ps-card.solution { background: linear-gradient(135deg, var(--mum-pink), var(--mum-deep)); }
  .ps-tag {
    font-size: 0.7rem; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase;
    margin-bottom: 20px; display: inline-block; padding: 4px 10px; border-radius: 100px;
  }
  .problem .ps-tag { background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.5); }
  .solution .ps-tag { background: rgba(255,255,255,0.2); color: rgba(255,255,255,0.9); }
  .ps-card h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.6rem; font-weight: 700; color: white; margin-bottom: 24px;
  }
  .ps-list { list-style: none; }
  .ps-list li {
    color: rgba(255,255,255,0.7); font-size: 0.9rem; padding: 10px 0;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    display: flex; align-items: flex-start; gap: 12px; line-height: 1.5;
  }
  .ps-list li:last-child { border-bottom: none; }
  .ps-list li span { flex-shrink: 0; font-size: 1rem; }
  .solution .ps-list li { color: rgba(255,255,255,0.88); }

  /* ─── ARCHITECTURE ─── */
  .arch-bg { background: var(--dark); }
  .arch-bg .section-title { color: white; }
  .arch-bg .section-title em { color: var(--mum-light); }
  .arch-bg .section-sub { color: rgba(255,255,255,0.5); }
  .arch-bg .section-label { background: rgba(232,21,125,0.2); color: var(--mum-light); }

  .pipeline {
    margin-top: 60px;
    display: grid; grid-template-columns: repeat(6, 1fr); gap: 0;
    align-items: stretch;
  }
  .pipe-step {
    background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
    padding: 28px 20px; position: relative; text-align: center;
    transition: background 0.3s;
  }
  .pipe-step:hover { background: rgba(232,21,125,0.1); border-color: rgba(232,21,125,0.3); }
  .pipe-step:first-child { border-radius: 16px 0 0 16px; }
  .pipe-step:last-child { border-radius: 0 16px 16px 0; border-right: 1px solid rgba(255,255,255,0.08); }
  .pipe-arrow {
    position: absolute; top: 50%; right: -14px; transform: translateY(-50%);
    z-index: 2; width: 28px; height: 28px; border-radius: 50%;
    background: linear-gradient(135deg, var(--mum-pink), var(--gold));
    display: flex; align-items: center; justify-content: center;
    color: white; font-size: 0.75rem; font-weight: 700;
  }
  .pipe-step:last-child .pipe-arrow { display: none; }
  .pipe-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem; color: var(--mum-light); font-weight: 500;
    letter-spacing: 1px; text-transform: uppercase; margin-bottom: 10px;
  }
  .pipe-icon { font-size: 1.6rem; margin-bottom: 10px; }
  .pipe-title { font-weight: 700; font-size: 0.8rem; color: white; margin-bottom: 6px; }
  .pipe-desc { font-size: 0.72rem; color: rgba(255,255,255,0.4); line-height: 1.4; }

  .arch-details {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 40px;
  }
  .arch-detail {
    background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06);
    border-radius: 16px; padding: 28px;
    transition: border-color 0.3s;
  }
  .arch-detail:hover { border-color: rgba(232,21,125,0.3); }
  .arch-detail-icon {
    width: 44px; height: 44px; border-radius: 12px;
    background: linear-gradient(135deg, rgba(232,21,125,0.2), rgba(244,166,35,0.1));
    display: flex; align-items: center; justify-content: center;
    font-size: 1.2rem; margin-bottom: 16px;
  }
  .arch-detail h4 { font-weight: 700; color: white; margin-bottom: 8px; font-size: 0.9rem; }
  .arch-detail p { font-size: 0.8rem; color: rgba(255,255,255,0.45); line-height: 1.6; }

  /* ─── FEATURES ─── */
  .features-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 60px;
  }
  .feat-card {
    background: white; border-radius: 20px; padding: 32px;
    border: 1px solid rgba(232,21,125,0.08); box-shadow: var(--shadow);
    transition: transform 0.25s, box-shadow 0.25s;
    position: relative; overflow: hidden;
  }
  .feat-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-deep); }
  .feat-card::after {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: linear-gradient(90deg, var(--mum-pink), var(--gold));
    transform: scaleX(0); transform-origin: left; transition: transform 0.3s;
  }
  .feat-card:hover::after { transform: scaleX(1); }
  .feat-icon {
    width: 52px; height: 52px; border-radius: 14px; margin-bottom: 20px;
    display: flex; align-items: center; justify-content: center; font-size: 1.4rem;
  }
  .feat-title { font-weight: 700; font-size: 1rem; color: var(--dark); margin-bottom: 10px; }
  .feat-desc { font-size: 0.85rem; color: var(--muted); line-height: 1.65; }
  .feat-tag {
    display: inline-block; margin-top: 16px;
    background: var(--mum-blush); color: var(--mum-deep);
    padding: 4px 10px; border-radius: 100px; font-size: 0.7rem; font-weight: 600;
    font-family: 'JetBrains Mono', monospace; letter-spacing: 0.3px;
  }

  /* ─── DEMO ─── */
  .demo-bg {
    background: linear-gradient(135deg, var(--mum-blush) 0%, rgba(255,211,232,0.3) 100%);
    border-top: 1px solid var(--mum-rose); border-bottom: 1px solid var(--mum-rose);
  }
  .demo-grid {
    display: grid; grid-template-columns: 1fr 1.4fr; gap: 60px; align-items: start; margin-top: 60px;
  }
  .demo-queries { display: flex; flex-direction: column; gap: 12px; }
  .demo-query-card {
    background: white; border-radius: 14px; padding: 18px 22px;
    border: 2px solid transparent; cursor: pointer;
    transition: all 0.2s; box-shadow: 0 2px 12px rgba(232,21,125,0.06);
  }
  .demo-query-card.active, .demo-query-card:hover {
    border-color: var(--mum-pink); box-shadow: 0 4px 20px rgba(232,21,125,0.15);
  }
  .demo-query-text { font-size: 0.875rem; font-weight: 600; color: var(--dark); margin-bottom: 4px; }
  .demo-query-type { font-size: 0.72rem; color: var(--muted); }
  .demo-query-dot {
    display: inline-block; width: 8px; height: 8px; border-radius: 50%;
    background: var(--mum-rose); margin-right: 6px;
    transition: background 0.2s;
  }
  .demo-query-card.active .demo-query-dot,
  .demo-query-card:hover .demo-query-dot { background: var(--mum-pink); }

  .demo-output {
    background: white; border-radius: 20px; padding: 32px;
    box-shadow: var(--shadow-deep); border: 1px solid rgba(232,21,125,0.1);
    min-height: 480px;
  }
  .demo-output-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 24px; padding-bottom: 16px;
    border-bottom: 1px solid var(--mum-rose);
  }
  .demo-output-title { font-weight: 700; font-size: 0.875rem; color: var(--dark); }
  .demo-badge-green {
    background: #DCFCE7; color: #166534; padding: 4px 10px; border-radius: 100px;
    font-size: 0.72rem; font-weight: 700;
  }
  .demo-badge-amber {
    background: #FEF9C3; color: #854D0E; padding: 4px 10px; border-radius: 100px;
    font-size: 0.72rem; font-weight: 700;
  }
  .demo-section { margin-bottom: 20px; }
  .demo-section-label {
    font-size: 0.68rem; font-weight: 700; letter-spacing: 1px; text-transform: uppercase;
    color: var(--mum-pink); margin-bottom: 8px;
  }
  .demo-comfort {
    background: var(--mum-blush); border-radius: 12px; padding: 14px 18px;
    font-size: 0.85rem; color: var(--text); line-height: 1.6;
    border-left: 3px solid var(--mum-pink);
  }
  .demo-products { display: flex; flex-direction: column; gap: 10px; }
  .demo-product {
    background: var(--white); border: 1px solid var(--mum-rose);
    border-radius: 12px; padding: 14px 18px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .demo-product-name { font-weight: 600; font-size: 0.85rem; color: var(--dark); }
  .demo-product-reason { font-size: 0.76rem; color: var(--muted); margin-top: 2px; }
  .demo-product-conf {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem; font-weight: 700; color: #166534;
    background: #DCFCE7; padding: 3px 8px; border-radius: 6px; white-space: nowrap;
  }
  .demo-bilingual {
    display: grid; grid-template-columns: 1fr 1fr; gap: 10px;
  }
  .demo-lang {
    background: var(--white); border: 1px solid var(--mum-rose);
    border-radius: 10px; padding: 12px 14px; font-size: 0.8rem; color: var(--text); line-height: 1.5;
  }
  .demo-lang strong { font-size: 0.65rem; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: var(--mum-pink); display: block; margin-bottom: 4px; }

  /* ─── EVALUATION ─── */
  .evals-grid {
    display: grid; grid-template-columns: repeat(5, 1fr); gap: 20px; margin-top: 60px;
  }
  .eval-card {
    background: white; border-radius: 18px; padding: 28px 24px; text-align: center;
    border: 1px solid rgba(232,21,125,0.08); box-shadow: var(--shadow);
    transition: transform 0.2s;
  }
  .eval-card:hover { transform: translateY(-3px); }
  .eval-metric-ring {
    width: 80px; height: 80px; border-radius: 50%; margin: 0 auto 16px;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Playfair Display', serif; font-size: 1.3rem; font-weight: 900; color: white;
    position: relative;
  }
  .ring-green { background: conic-gradient(#22C55E 0deg 306deg, #e5e7eb 306deg 360deg); }
  .ring-pink { background: conic-gradient(var(--mum-pink) 0deg 324deg, #e5e7eb 324deg 360deg); }
  .ring-full { background: conic-gradient(var(--gold) 0deg 360deg, #e5e7eb 0deg); }
  .ring-blue { background: conic-gradient(#3B82F6 0deg 360deg, #e5e7eb 0deg); }
  .ring-check { background: conic-gradient(#8B5CF6 0deg 360deg, #e5e7eb 0deg); }
  .ring-inner {
    width: 62px; height: 62px; border-radius: 50%; background: white;
    position: absolute; display: flex; align-items: center; justify-content: center;
    font-family: 'DM Sans', sans-serif; font-size: 1rem; font-weight: 800;
  }
  .ring-green .ring-inner { color: #22C55E; }
  .ring-pink .ring-inner { color: var(--mum-pink); }
  .ring-full .ring-inner { color: var(--gold); }
  .ring-blue .ring-inner { color: #3B82F6; }
  .ring-check .ring-inner { color: #8B5CF6; }
  .eval-name { font-weight: 700; font-size: 0.85rem; color: var(--dark); margin-bottom: 4px; }
  .eval-target { font-size: 0.72rem; color: var(--muted); }

  /* ─── METRICS ─── */
  .metrics-grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; margin-top: 60px;
  }
  .metric-card {
    background: white; border-radius: 20px; padding: 32px;
    border: 1px solid rgba(232,21,125,0.08); box-shadow: var(--shadow);
  }
  .metric-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 16px; }
  .metric-label { font-size: 0.85rem; color: var(--muted); font-weight: 500; }
  .metric-value {
    font-family: 'Playfair Display', serif;
    font-size: 2.8rem; font-weight: 900; color: var(--dark);
  }
  .metric-change {
    font-size: 0.78rem; font-weight: 700; padding: 3px 8px; border-radius: 8px;
  }
  .up { background: #DCFCE7; color: #166534; }
  .down { background: #DCFCE7; color: #166534; }
  .metric-bar-wrap { height: 6px; background: var(--mum-rose); border-radius: 100px; overflow: hidden; }
  .metric-bar { height: 100%; border-radius: 100px; background: linear-gradient(90deg, var(--mum-pink), var(--gold)); }
  .metric-desc { font-size: 0.78rem; color: var(--muted); margin-top: 10px; line-height: 1.5; }

  /* ─── CODE ─── */
  .code-bg { background: var(--dark); }
  .code-bg .section-title { color: white; }
  .code-bg .section-title em { color: var(--mum-light); }
  .code-bg .section-sub { color: rgba(255,255,255,0.5); }
  .code-bg .section-label { background: rgba(232,21,125,0.2); color: var(--mum-light); }

  .code-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; margin-top: 60px; }
  .code-block {
    background: rgba(0,0,0,0.4); border: 1px solid rgba(255,255,255,0.06);
    border-radius: 16px; overflow: hidden;
  }
  .code-header {
    display: flex; align-items: center; gap: 8px; padding: 12px 18px;
    background: rgba(255,255,255,0.04); border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .dot { width: 10px; height: 10px; border-radius: 50%; }
  .dot-r { background: #FF5F57; } .dot-y { background: #FFBD2E; } .dot-g { background: #27C93F; }
  .code-filename { font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; color: rgba(255,255,255,0.3); margin-left: auto; }
  pre {
    padding: 20px; font-family: 'JetBrains Mono', monospace; font-size: 0.76rem;
    line-height: 1.7; color: rgba(255,255,255,0.75); overflow-x: auto;
  }
  .kw { color: #FF79C6; } .fn { color: #8BE9FD; } .str { color: #F1FA8C; }
  .cm { color: rgba(255,255,255,0.3); font-style: italic; } .num { color: #BD93F9; }
  .var { color: #50FA7B; }

  /* ─── STRUCTURE ─── */
  .structure-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 60px; margin-top: 60px; align-items: start;
  }
  .file-tree {
    background: var(--dark); border-radius: 20px; overflow: hidden;
  }
  .file-tree-header {
    padding: 16px 22px; background: rgba(255,255,255,0.04);
    border-bottom: 1px solid rgba(255,255,255,0.08);
    display: flex; align-items: center; gap: 8px;
  }
  .file-tree-header span { font-family: 'JetBrains Mono', monospace; font-size: 0.78rem; color: rgba(255,255,255,0.4); }
  .file-tree-body { padding: 20px 22px; font-family: 'JetBrains Mono', monospace; font-size: 0.78rem; line-height: 2; }
  .ft-dir { color: #8BE9FD; }
  .ft-file { color: rgba(255,255,255,0.55); }
  .ft-comment { color: rgba(255,255,255,0.25); margin-left: 8px; }
  .ft-line { display: flex; align-items: center; }
  .ft-indent-1 { padding-left: 20px; }
  .ft-indent-2 { padding-left: 40px; }
  .ft-indent-3 { padding-left: 60px; }

  .decisions-list { display: flex; flex-direction: column; gap: 20px; }
  .decision-card {
    background: white; border-radius: 16px; padding: 24px;
    border: 1px solid rgba(232,21,125,0.08); box-shadow: var(--shadow);
  }
  .decision-card h4 { font-weight: 700; color: var(--dark); margin-bottom: 8px; font-size: 0.95rem; }
  .decision-card p { font-size: 0.82rem; color: var(--muted); line-height: 1.6; }
  .decision-pros-cons { display: flex; gap: 16px; margin-top: 12px; }
  .pros, .cons {
    flex: 1; padding: 10px 14px; border-radius: 10px; font-size: 0.76rem; line-height: 1.6;
  }
  .pros { background: #F0FDF4; color: #166534; border: 1px solid #BBF7D0; }
  .cons { background: #FFF7ED; color: #9A3412; border: 1px solid #FED7AA; }
  .pros strong, .cons strong { display: block; font-size: 0.68rem; letter-spacing: 0.8px; text-transform: uppercase; margin-bottom: 4px; }

  /* ─── IMPACT ─── */
  .impact-bg {
    background: linear-gradient(160deg, var(--dark) 0%, var(--dark-mid) 60%, var(--mum-deep) 100%);
  }
  .impact-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 60px;
  }
  .impact-card {
    background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
    border-radius: 20px; padding: 32px; text-align: center;
    transition: background 0.3s;
  }
  .impact-card:hover { background: rgba(255,255,255,0.1); }
  .impact-icon { font-size: 2rem; margin-bottom: 16px; }
  .impact-title { font-family: 'Playfair Display', serif; font-size: 1.3rem; font-weight: 700; color: white; margin-bottom: 10px; }
  .impact-val { font-size: 2rem; font-weight: 900; color: var(--gold); margin-bottom: 8px; }
  .impact-desc { font-size: 0.8rem; color: rgba(255,255,255,0.5); line-height: 1.6; }
  .impact-bg .section-title { color: white; }
  .impact-bg .section-title em { color: var(--mum-light); }
  .impact-bg .section-sub { color: rgba(255,255,255,0.5); }
  .impact-bg .section-label { background: rgba(232,21,125,0.2); color: var(--mum-light); }

  /* ─── FOOTER ─── */
  footer {
    position: relative; z-index: 1;
    background: var(--dark);
    padding: 60px;
    text-align: center;
    border-top: 1px solid rgba(255,255,255,0.06);
  }
  .footer-logo {
    display: inline-flex; align-items: center; gap: 12px; margin-bottom: 20px;
  }
  .footer-tagline { font-size: 0.875rem; color: rgba(255,255,255,0.35); margin-bottom: 32px; }
  .footer-tags { display: flex; justify-content: center; gap: 10px; flex-wrap: wrap; }
  .footer-tag {
    background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.4); padding: 5px 14px; border-radius: 100px;
    font-size: 0.72rem; font-weight: 500;
  }
  .footer-copy { margin-top: 40px; font-size: 0.75rem; color: rgba(255,255,255,0.2); }

  /* ─── ANIMATIONS ─── */
  .fade-up {
    opacity: 0; transform: translateY(30px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .fade-up.visible { opacity: 1; transform: translateY(0); }
  .fade-up-d1 { transition-delay: 0.1s; }
  .fade-up-d2 { transition-delay: 0.2s; }
  .fade-up-d3 { transition-delay: 0.3s; }
  .fade-up-d4 { transition-delay: 0.4s; }
  .fade-up-d5 { transition-delay: 0.5s; }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 1024px) {
    nav { padding: 16px 24px; }
    .nav-links { display: none; }
    .hero, .section-wrap { padding-left: 24px; padding-right: 24px; }
    .hero-grid, .ps-grid, .demo-grid, .structure-grid, .code-grid { grid-template-columns: 1fr; }
    .pipeline { grid-template-columns: repeat(3, 1fr); }
    .stats-inner { grid-template-columns: repeat(3, 1fr); }
    .evals-grid { grid-template-columns: repeat(3, 1fr); }
    .features-grid, .impact-grid, .metrics-grid, .arch-details { grid-template-columns: repeat(2, 1fr); }
    .stats-row { padding: 40px 24px; }
    footer { padding: 40px 24px; }
  }
  @media (max-width: 640px) {
    .pipeline { grid-template-columns: repeat(2, 1fr); }
    .stats-inner { grid-template-columns: repeat(2, 1fr); }
    .evals-grid, .features-grid, .impact-grid, .arch-details { grid-template-columns: 1fr; }
    .metrics-grid { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>

<!-- ─── NAV ─── -->
<nav>
  <div class="nav-logo">
    <div class="nav-logo-mark">M</div>
    <div class="nav-brand">MumCare <span>AI</span></div>
  </div>
  <ul class="nav-links">
    <li><a href="#problem">Problem</a></li>
    <li><a href="#architecture">Architecture</a></li>
    <li><a href="#features">Features</a></li>
    <li><a href="#demo">Demo</a></li>
    <li><a href="#eval">Evaluation</a></li>
    <li><a href="#impact">Impact</a></li>
  </ul>
  <a href="#demo" class="nav-badge">View Live Demo ↗</a>
</nav>

<!-- ─── HERO ─── -->
<section class="hero" id="top">
  <div class="hero-grid">
    <div>
      <div class="hero-eyebrow">Mumzworld AI Intern Assignment</div>
      <h1 class="hero-title">
        AI-Native<br />
        Decision Engine<br />
        for <em>Mothers</em>
      </h1>
      <p class="hero-sub">
        MumCare AI replaces filter-based navigation with intelligent, empathetic assistance — understanding intent, retrieving real products, and generating structured guidance in both English and Arabic.
      </p>
      <div class="hero-ctas">
        <a href="#demo" class="btn-primary">↓ Explore the System</a>
        <a href="#architecture" class="btn-outline">View Architecture →</a>
      </div>
    </div>

    <div class="hero-visual">
      <div class="float-pill p1">🎯 Intent Detected: postpartum_care</div>
      <div class="hero-card fade-up">
        <div class="chat-header">
          <div class="chat-avatar">M</div>
          <div>
            <div class="chat-title">MumCare AI Assistant</div>
            <div class="chat-status">Online · RAG Active</div>
          </div>
        </div>
        <div class="chat-msg user">
          <div class="chat-bubble user-bubble">I have leakage after childbirth</div>
        </div>
        <div class="chat-msg">
          <div class="chat-bubble ai-bubble">
            This is completely normal and you are not alone. Postpartum leakage affects many new mothers — it's your body recovering. Here are some products that can help:
            <div class="product-chips">
              <div class="product-chip">Comfort Nursing Pads</div>
              <div class="product-chip">Postpartum Underwear</div>
              <div class="product-chip">Maternity Pads</div>
            </div>
          </div>
        </div>
        <div class="confidence-bar">
          ✓ &nbsp;Confidence: 95% · Uncertainty: false · Bilingual output ready
        </div>
      </div>
      <div class="float-pill p2">🛡️ Zero Hallucination · RAG Grounded</div>
    </div>
  </div>
</section>

<!-- ─── STATS ─── -->
<div class="stats-row">
  <div class="stats-inner">
    <div class="stat-item fade-up">
      <div class="stat-num">>85%</div>
      <div class="stat-label">Intent Accuracy</div>
    </div>
    <div class="stat-item fade-up fade-up-d1">
      <div class="stat-num">0%</div>
      <div class="stat-label">Hallucination Rate</div>
    </div>
    <div class="stat-item fade-up fade-up-d2">
      <div class="stat-num">6</div>
      <div class="stat-label">Pipeline Steps</div>
    </div>
    <div class="stat-item fade-up fade-up-d3">
      <div class="stat-num">10+</div>
      <div class="stat-label">Eval Test Cases</div>
    </div>
    <div class="stat-item fade-up fade-up-d4">
      <div class="stat-num">2</div>
      <div class="stat-label">Languages (EN + AR)</div>
    </div>
  </div>
</div>

<!-- ─── PROBLEM / SOLUTION ─── -->
<section id="problem">
  <div class="section-wrap">
    <div class="section-label">The Challenge</div>
    <h2 class="section-title">What We <em>Solve</em></h2>
    <p class="section-sub">Postpartum mothers face overwhelming product decisions at their most vulnerable. Traditional e-commerce fails them.</p>
    <div class="ps-grid">
      <div class="ps-card problem fade-up">
        <div class="ps-tag">❌ The Old Way</div>
        <h3>Traditional E-Commerce Friction</h3>
        <ul class="ps-list">
          <li><span>😰</span>Manual category navigation requires product knowledge</li>
          <li><span>🔍</span>Complex filters create decision paralysis</li>
          <li><span>📋</span>Generic listings with no personalized guidance</li>
          <li><span>🌐</span>English-only experiences for Arabic speakers</li>
          <li><span>⚠️</span>No safety signals for medical concerns</li>
          <li><span>🕐</span>High decision time leads to cart abandonment</li>
        </ul>
      </div>
      <div class="ps-card solution fade-up fade-up-d2">
        <div class="ps-tag">✅ MumCare AI</div>
        <h3>Intent-Driven Decision Engine</h3>
        <ul class="ps-list">
          <li><span>💬</span>Natural language input — no product knowledge needed</li>
          <li><span>🧠</span>AI understands context, intent, and emotion</li>
          <li><span>📦</span>RAG retrieval ensures only real, relevant products</li>
          <li><span>🌍</span>Native bilingual output in English and Arabic</li>
          <li><span>🏥</span>Automatic medical uncertainty flagging for safety</li>
          <li><span>⚡</span>Structured JSON output for seamless integration</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- ─── ARCHITECTURE ─── -->
<section id="architecture" class="arch-bg">
  <div class="section-wrap">
    <div class="section-label">System Design</div>
    <h2 class="section-title">6-Step AI <em>Pipeline</em></h2>
    <p class="section-sub">A production-grade pipeline combining RAG, structured output, multilingual generation, and uncertainty handling.</p>

    <div class="pipeline fade-up">
      <div class="pipe-step">
        <div class="pipe-arrow">→</div>
        <div class="pipe-num">Step 01</div>
        <div class="pipe-icon">🎯</div>
        <div class="pipe-title">Intent Parser</div>
        <div class="pipe-desc">Classifies user intent, detects medical urgency, calculates confidence</div>
      </div>
      <div class="pipe-step">
        <div class="pipe-arrow">→</div>
        <div class="pipe-num">Step 02</div>
        <div class="pipe-icon">💛</div>
        <div class="pipe-title">Comfort Layer</div>
        <div class="pipe-desc">Generates empathetic bilingual response normalizing user concern</div>
      </div>
      <div class="pipe-step">
        <div class="pipe-arrow">→</div>
        <div class="pipe-num">Step 03</div>
        <div class="pipe-icon">🔍</div>
        <div class="pipe-title">RAG Retriever</div>
        <div class="pipe-desc">Keyword + tag matching fetches top-5 relevant real products</div>
      </div>
      <div class="pipe-step">
        <div class="pipe-arrow">→</div>
        <div class="pipe-num">Step 04</div>
        <div class="pipe-icon">🤖</div>
        <div class="pipe-title">LLM Engine</div>
        <div class="pipe-desc">Reasons only over retrieved data — structured JSON output</div>
      </div>
      <div class="pipe-step">
        <div class="pipe-arrow">→</div>
        <div class="pipe-num">Step 05</div>
        <div class="pipe-icon">🛡️</div>
        <div class="pipe-title">Guidance Layer</div>
        <div class="pipe-desc">Context-aware safety disclaimers and follow-up support info</div>
      </div>
      <div class="pipe-step">
        <div class="pipe-num">Step 06</div>
        <div class="pipe-icon">✅</div>
        <div class="pipe-title">Validator</div>
        <div class="pipe-desc">Schema validation, confidence bounds, final structured output</div>
      </div>
    </div>

    <div class="arch-details fade-up">
      <div class="arch-detail">
        <div class="arch-detail-icon">📚</div>
        <h4>RAG (Retrieval-Augmented Generation)</h4>
        <p>All product recommendations are grounded in real catalog data. The LLM cannot hallucinate products — it only reasons over what the retriever returns.</p>
      </div>
      <div class="arch-detail">
        <div class="arch-detail-icon">🔒</div>
        <h4>Structured Output + Pydantic Validation</h4>
        <p>Strict JSON schema enforced via Pydantic models prevents malformed responses and ensures every API response is predictable and integration-ready.</p>
      </div>
      <div class="arch-detail">
        <div class="arch-detail-icon">⚠️</div>
        <h4>Uncertainty Handling</h4>
        <p>The system explicitly detects low-confidence and unsafe medical queries, setting <code style="color:var(--mum-light);font-family:JetBrains Mono,monospace;font-size:0.75em">uncertainty=true</code> and routing to professional guidance instead of products.</p>
      </div>
    </div>
  </div>
</section>

<!-- ─── FEATURES ─── -->
<section id="features">
  <div class="section-wrap">
    <div class="section-label">Core Components</div>
    <h2 class="section-title">Non-Trivial <em>AI Engineering</em></h2>
    <p class="section-sub">This is not a prompt wrapper. Each component represents a distinct AI engineering pattern working in concert.</p>

    <div class="features-grid">
      <div class="feat-card fade-up">
        <div class="feat-icon" style="background: linear-gradient(135deg, rgba(232,21,125,0.15), rgba(244,166,35,0.08));">🧩</div>
        <div class="feat-title">RAG-Lite Retrieval</div>
        <div class="feat-desc">Keyword + tag-based retrieval against a structured product catalog. Fast, debuggable, and hallucination-proof. Swappable with full vector DB in production.</div>
        <div class="feat-tag">retriever.py</div>
      </div>
      <div class="feat-card fade-up fade-up-d1">
        <div class="feat-icon" style="background: linear-gradient(135deg, rgba(59,130,246,0.12), rgba(139,92,246,0.08));">🎯</div>
        <div class="feat-title">Intent Classification</div>
        <div class="feat-desc">LLM classifies queries into postpartum_care, feeding, baby_care, general, or unknown — with explicit confidence scores and medical flagging.</div>
        <div class="feat-tag">intent_parser.py</div>
      </div>
      <div class="feat-card fade-up fade-up-d2">
        <div class="feat-icon" style="background: linear-gradient(135deg, rgba(34,197,94,0.12), rgba(16,185,129,0.08));">🛡️</div>
        <div class="feat-title">Uncertainty Handling</div>
        <div class="feat-desc">System detects ambiguous or medically urgent inputs and responds with safety guidance instead of product recommendations — safety over false confidence.</div>
        <div class="feat-tag">validator.py</div>
      </div>
      <div class="feat-card fade-up fade-up-d3">
        <div class="feat-icon" style="background: linear-gradient(135deg, rgba(244,166,35,0.15), rgba(234,88,12,0.08));">🌍</div>
        <div class="feat-title">Native Bilingual Output</div>
        <div class="feat-desc">English and Arabic generated in the same LLM call — not translation. Ensures natural phrasing, cultural appropriateness, and no translation artifacts.</div>
        <div class="feat-tag">generator.py</div>
      </div>
      <div class="feat-card fade-up fade-up-d4">
        <div class="feat-icon" style="background: linear-gradient(135deg, rgba(139,92,246,0.12), rgba(217,70,239,0.08));">📊</div>
        <div class="feat-title">Evaluation Harness</div>
        <div class="feat-desc">10+ automated test cases with measurable scoring across intent accuracy, recommendation relevance, hallucination rate, and uncertainty handling.</div>
        <div class="feat-tag">evaluator.py</div>
      </div>
      <div class="feat-card fade-up fade-up-d5">
        <div class="feat-icon" style="background: linear-gradient(135deg, rgba(232,21,125,0.12), rgba(176,16,96,0.08));">⚡</div>
        <div class="feat-title">FastAPI + Streamlit</div>
        <div class="feat-desc">Production-grade REST API with OpenAPI docs, health checks, and a Streamlit frontend for live demonstration. Clean separation of concerns throughout.</div>
        <div class="feat-tag">main.py · app.py</div>
      </div>
    </div>
  </div>
</section>

<!-- ─── DEMO ─── -->
<section id="demo" class="demo-bg">
  <div class="section-wrap">
    <div class="section-label">Live System Output</div>
    <h2 class="section-title">See It in <em>Action</em></h2>
    <p class="section-sub">Real system responses across core use cases, edge cases, and safety scenarios.</p>

    <div class="demo-grid">
      <div>
        <div style="font-size:0.78rem; font-weight:700; color:var(--mum-pink); letter-spacing:1px; text-transform:uppercase; margin-bottom:12px;">Example Queries</div>
        <div class="demo-queries">
          <div class="demo-query-card active" onclick="showDemo(0, this)">
            <div class="demo-query-text"><span class="demo-query-dot"></span>"I have cracked nipples from breastfeeding"</div>
            <div class="demo-query-type">Mother care · Feeding support</div>
          </div>
          <div class="demo-query-card" onclick="showDemo(1, this)">
            <div class="demo-query-text"><span class="demo-query-dot"></span>"My newborn won't sleep, need help"</div>
            <div class="demo-query-type">Baby care · Sleep solutions</div>
          </div>
          <div class="demo-query-card" onclick="showDemo(2, this)">
            <div class="demo-query-text"><span class="demo-query-dot"></span>"I have leakage and heavy bleeding postpartum"</div>
            <div class="demo-query-type">Mother care · Postpartum recovery</div>
          </div>
          <div class="demo-query-card" onclick="showDemo(3, this)">
            <div class="demo-query-text"><span class="demo-query-dot"></span>"My baby has a bad diaper rash"</div>
            <div class="demo-query-type">Baby care · Skin care</div>
          </div>
          <div class="demo-query-card" onclick="showDemo(4, this)">
            <div class="demo-query-text"><span class="demo-query-dot"></span>"What is your company name?"</div>
            <div class="demo-query-type">Out-of-scope · Graceful fallback</div>
          </div>
        </div>
      </div>

      <div class="demo-output" id="demo-output">
        <!-- filled by JS -->
      </div>
    </div>
  </div>
</section>

<!-- ─── EVALUATION ─── -->
<section id="eval">
  <div class="section-wrap">
    <div class="section-label">Evaluation Harness</div>
    <h2 class="section-title">Measurable, <em>Scored</em> Results</h2>
    <p class="section-sub">10+ automated test cases with objective metrics — not subjective reviews.</p>

    <div class="evals-grid fade-up">
