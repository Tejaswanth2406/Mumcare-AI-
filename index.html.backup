    uncertainty: false
  },
  {
    query: "What is your company name?",
    badge: '<div class="demo-badge-amber">⚠️ Out of Scope</div>',
    intent: "unknown",
    comfort_en: "That's a great question, but it's outside my specialty! I'm MumCare AI, here to help you and your baby with product recommendations and guidance for maternal and infant care.",
    comfort_ar: "هذا سؤال جميل لكنه خارج نطاق تخصصي. أنا هنا لمساعدتكِ وطفلكِ في رعايتكما.",
    products: [],
    guidance: "I specialize in mother's health, baby care, feeding support, and newborn essentials. Ask me about postpartum recovery, baby sleep, feeding challenges, or infant care products!",
    uncertainty: true
  }
];

function showDemo(i, el) {
  document.querySelectorAll('.demo-query-card').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
  const d = demos[i];
  const out = document.getElementById('demo-output');
  const intentColor = d.uncertainty ? '#854D0E' : 'var(--mum-deep)';
  const intentBg = d.uncertainty ? '#FEF9C3' : 'var(--mum-blush)';

  const productsHTML = d.products.length > 0
    ? `<div class="demo-section">
        <div class="demo-section-label">Recommended Products</div>
        <div class="demo-products">
          ${d.products.map(p => `
            <div class="demo-product">
              <div>
                <div class="demo-product-name">📦 ${p.name}</div>
                <div class="demo-product-reason">${p.reason}</div>
              </div>
              <div class="demo-product-conf">${p.conf}</div>
            </div>
          `).join('')}
        </div>
      </div>`
    : `<div class="demo-section">
        <div class="demo-section-label">Recommendations</div>
        <div style="background:#FEF9C3; border:1px solid #FDE68A; border-radius:12px; padding:14px 18px; font-size:0.85rem; color:#854D0E; border-left:3px solid #F59E0B;">
          No product recommendations — ${d.uncertainty ? 'medical/safety concern detected' : 'out-of-scope query'}. Safety guidance provided instead.
        </div>
      </div>`;

  out.innerHTML = `
    <div class="demo-output-header">
      <div class="demo-output-title">System Output</div>
      ${d.badge}
    </div>
    <div class="demo-section">
      <div class="demo-section-label">Intent Detected</div>
      <span style="background:${intentBg}; color:${intentColor}; padding:4px 12px; border-radius:100px; font-size:0.75rem; font-weight:700; font-family:'JetBrains Mono',monospace;">${d.intent}</span>
    </div>
    <div class="demo-section">
      <div class="demo-section-label">Comfort Message</div>
      <div class="demo-bilingual">
        <div class="demo-lang"><strong>English</strong>${d.comfort_en}</div>
        <div class="demo-lang"><strong>Arabic</strong>${d.comfort_ar}</div>
      </div>
    </div>
    ${productsHTML}
    <div class="demo-section">
      <div class="demo-section-label">Guidance</div>
      <div class="demo-comfort">${d.guidance}</div>
    </div>
  `;
}

// Initialize first demo
showDemo(0, document.querySelector('.demo-query-card'));
</script>
</body>
</html>